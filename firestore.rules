rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each player can read and write only their own document.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
